<mvc:View
    controllerName="mobileappsignport.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="page"
        showNavButton="false"
        showHeader="true"
        busy="{view>/busy}"
        busyIndicatorDelay="0">

        <customHeader>
            <OverflowToolbar design="Info">
                <core:Icon src="sap-icon://connected" class="sapUiTinyMarginEnd" />
                <Title text="FSM Web Container" level="H4" />
                <ToolbarSpacer />
                <ObjectStatus
                    text="{= ${view>/context/source} === 'mobile' ? 'Mobile App' : 'Web UI' }"
                    state="Success"
                    visible="{view>/contextLoaded}" />
                <ObjectStatus
                    text="{view>/context/objectType}"
                    state="Information"
                    visible="{view>/contextLoaded}" />
            </OverflowToolbar>
        </customHeader>

        <content>

            <!-- Not opened from FSM -->
            <IllustratedMessage
                visible="{view>/showError}"
                illustrationType="sapIllus-NoMail"
                title="Open from FSM"
                description="Open this app from FSM Mobile (Web Container) or FSM Web UI (Shell Extension)." />

            <!-- Context + Attachments -->
            <layout:VerticalLayout
                visible="{view>/contextLoaded}"
                width="100%"
                class="sapUiContentPadding">

                <!-- ── Session Context ──────────────────────────────── -->
                <List
                    id="contextList"
                    headerText="Session Context"
                    mode="None"
                    showSeparators="Inner"
                    class="sapUiSmallMarginBottom">

                    <ObjectListItem
                        title="{view>/context/userName}"
                        intro="User"
                        icon="sap-icon://account" />

                    <ObjectListItem
                        title="{view>/context/companyName}"
                        intro="Company"
                        icon="sap-icon://factory" />

                    <ObjectListItem
                        title="{view>/context/cloudAccount}"
                        intro="Cloud Account"
                        icon="sap-icon://cloud" />

                    <ObjectListItem
                        title="{view>/context/cloudId}"
                        intro="Cloud ID / Object ID"
                        icon="sap-icon://key-user-settings" />

                    <ObjectListItem
                        title="{view>/context/objectType}"
                        intro="Object Type"
                        icon="sap-icon://activity-2" />

                    <ObjectListItem
                        title="{view>/context/language}"
                        intro="Language"
                        icon="sap-icon://globe" />

                    <ObjectListItem
                        title="{view>/context/dataCloudFullQualifiedDomainName}"
                        intro="FSM Cloud Domain"
                        icon="sap-icon://world" />

                    <ObjectListItem
                        title="{view>/context/authToken}"
                        intro="Auth Token"
                        icon="sap-icon://locked" />

                </List>

                <!-- ── Attachments Table ───────────────────────────── -->
                <Table
                    id="attachmentsTable"
                    headerText="Attachments"
                    items="{view>/attachments}"
                    busy="{view>/attachmentsBusy}"
                    busyIndicatorDelay="0"
                    noDataText="No attachments found">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Attachments" level="H5" />
                            <ToolbarSpacer />
                            <ObjectStatus
                                text="{= ${view>/attachments}.length + ' item(s)'}"
                                visible="{view>/attachmentsLoaded}" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="25%">
                            <Text text="File Name" />
                        </Column>
                        <Column width="15%">
                            <Text text="Type" />
                        </Column>
                        <Column width="20%">
                            <Text text="ID" />
                        </Column>
                        <Column width="25%">
                            <Text text="Content (preview)" />
                        </Column>
                        <Column width="15%">
                            <Text text="Content-Type" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <Text text="{view>fileName}" />
                                <Text text="{view>type}" />
                                <Text text="{view>id}" />
                                <Text text="{view>content}" wrapping="false" />
                                <Text text="{view>contentType}" />
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

            </layout:VerticalLayout>

        </content>

    </Page>
</mvc:View>