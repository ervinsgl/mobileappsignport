<mvc:View
    controllerName="mobileappsignport.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core"
    displayBlock="true">

    <Page
        id="page"
        showNavButton="false"
        showHeader="true"
        busy="{view>/busy}"
        busyIndicatorDelay="0">

        <customHeader>
            <OverflowToolbar design="Info">
                <core:Icon src="sap-icon://connected" class="sapUiTinyMarginEnd" />
                <Title text="FSM Web Container" level="H4" />
                <ToolbarSpacer />
                <ObjectStatus
                    text="{= ${view>/context/source} === 'mobile' ? 'Mobile App' : 'Web UI' }"
                    state="Success"
                    visible="{view>/contextLoaded}" />
                <ObjectStatus
                    text="{view>/context/objectType}"
                    state="Information"
                    visible="{view>/contextLoaded}" />
            </OverflowToolbar>
        </customHeader>

        <content>

            <!-- Not opened from FSM -->
            <IllustratedMessage
                visible="{view>/showError}"
                illustrationType="sapIllus-NoMail"
                title="Open from FSM"
                description="Open this app from FSM Mobile (Web Container) or FSM Web UI (Shell Extension)." />

            <layout:VerticalLayout
                visible="{view>/contextLoaded}"
                width="100%"
                class="sapUiContentPadding">

                <!-- ── Attachments table ───────────────────────────────── -->
                <Table
                    id="attachmentsTable"
                    items="{view>/attachments}"
                    busy="{view>/attachmentsBusy}"
                    busyIndicatorDelay="0"
                    noDataText="No attachments found"
                    class="sapUiSmallMarginBottom">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="Attachments" level="H5" />
                            <ToolbarSpacer />
                            <ObjectStatus
                                text="{= ${view>/attachments}.length + ' item(s)'}"
                                visible="{view>/attachmentsLoaded}" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <columns>
                        <Column width="8%">
                            <Text text="" />
                        </Column>
                        <Column width="12%">
                            <Text text="File Name" />
                        </Column>
                        <Column width="8%">
                            <Text text="Type" />
                        </Column>
                        <Column width="16%">
                            <Text text="ID" />
                        </Column>
                        <Column width="18%">
                            <Text text="Content (preview)" />
                        </Column>
                        <Column width="10%">
                            <Text text="Content-Type" />
                        </Column>
                        <Column width="10%">
                            <Text text="User" />
                        </Column>
                        <Column width="8%">
                            <Text text="Language" />
                        </Column>
                        <Column width="10%">
                            <Text text="Auth Token" />
                        </Column>
                    </columns>

                    <items>
                        <ColumnListItem>
                            <cells>
                                <!-- Sign button -->
                                <Button
                                    text="{= ${view>signed} ? 'Signed!' : 'Sign PDF' }"
                                    type="{= ${view>signed} ? 'Success' : 'Emphasized' }"
                                    enabled="{= !${view>signed} }"
                                    press="onSignPress" />
                                <!-- File name → opens PDF inline -->
                                <Link
                                    text="{view>fileName}"
                                    press="onFileNamePress"
                                    wrapping="false" />
                                <Text text="{view>type}" />
                                <Text text="{view>id}" />
                                <Text text="{view>content}" wrapping="false" />
                                <Text text="{view>contentType}" />
                                <!-- Context fields – absolute paths, same value every row -->
                                <Text text="{view>/context/userName}" />
                                <Text text="{view>/context/language}" />
                                <Text text="{view>/context/authToken}" wrapping="false" />
                            </cells>
                        </ColumnListItem>
                    </items>

                </Table>

                <!-- ── Inline PDF viewer ───────────────────────────────── -->
                <Panel
                    id="pdfPanel"
                    visible="{= !!${view>/pdfUrl} }"
                    width="100%">

                    <headerToolbar>
                        <OverflowToolbar>
                            <Title text="{view>/pdfFileName}" level="H5" />
                            <ToolbarSpacer />
                            <Button
                                text="Close"
                                icon="sap-icon://decline"
                                press="onClosePdf" />
                        </OverflowToolbar>
                    </headerToolbar>

                    <PDFViewer
                        id="pdfViewer"
                        source="{view>/pdfUrl}"
                        isTrustedSource="true"
                        showDownloadButton="true"
                        height="600px"
                        width="100%" />

                </Panel>

            </layout:VerticalLayout>

        </content>

    </Page>
</mvc:View>